# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/mars_noise
REDIS_URL=redis://localhost:6379/0

# App
APP_ENV=development
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1/noise

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
CORS_HEADERS=["Content-Type","Authorization","X-Request-ID"]

# Ollama Cloud
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_API_KEY=your-ollama-api-key-here
OLLAMA_MODEL=glm-5.1:cloud

# LLM API Keys (optional, for future provider support)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# AI Settings
AI_MAX_TOKENS=4000
AI_TEMPERATURE=0.7
AI_CACHE_ENABLED=true
AI_CONFIDENCE_THRESHOLD=0.7

# Auth
JWT_SECRET_KEY=your-jwt-secret-key-here-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Keygen.sh Licensing
KEYGEN_API_URL=https://api.keygen.sh/v1
KEYGEN_ACCOUNT_ID=
KEYGEN_PRODUCT_ID=
KEYGEN_ADMIN_TOKEN=
LICENSE_GRACE_PERIOD_HOURS=24

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=true