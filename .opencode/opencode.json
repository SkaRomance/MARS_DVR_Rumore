{
  "$schema": "https://opencode.ai/config.json",
  "model": "ollama/glm-5.1:cloud",
  "provider": {
    "ollama": {
      "name": "Ollama Cloud",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1",
        "apiKey": "{env:OLLAMA_API_KEY}"
      },
      "models": {
        "glm-5.1:cloud": {
          "_launch": true,
          "limit": {
            "context": 202752,
            "output": 131072
          },
          "name": "glm-5.1:cloud"
        },
        "glm-5:cloud": {
          "_launch": true,
          "limit": {
            "context": 202752,
            "output": 131072
          },
          "name": "glm-5:cloud"
        },
        "minimax-m2.7:cloud": {
          "_launch": true,
          "limit": {
            "context": 204800,
            "output": 128000
          },
          "name": "minimax-m2.7:cloud"
        }
      }
    }
  }
}
